{
  "name": "straeto",
  "version": "0.1.5",
  "description": "Strætó — Icelandic bus system CLI",
  "author": "magtastic",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/magtastic/straeto-cli.git"
  },
  "keywords": [
    "straeto",
    "iceland",
    "bus",
    "cli",
    "bun",
    "reykjavik"
  ],
  "module": "src/cli.ts",
  "type": "module",
  "bin": {
    "straeto": "src/cli.ts"
  },
  "files": [
    "src",
    "icon.png",
    "README.md"
  ],
  "scripts": {
    "start": "bun run src/cli.ts",
    "lint": "biome check src",
    "lint:fix": "biome check --write src",
    "format": "biome format --write src",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "release": "bun test && npm version patch && git push --tags"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.6",
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "chalk": "5",
    "commander": "13",
    "zod": "^4.3.6"
  }
}
